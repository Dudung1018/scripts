[Script]
http-request ^https:\/\/api\.wetalkapp\.com\/app\/queryBalanceAndBonus script-path=https://sc.101825.xyz/script/WeTalk.js, requires-body=false, timeout=60, tag=WeTalk_Capture, enabled={{capture}}

cron "{{cronexp}}" script-path=https://sc.101825.xyz/script/WeTalk.js, timeout=300, tag=WeTalk_Cron, enabled={{cron}}

[MITM]
hostname = api.wetalkapp.com